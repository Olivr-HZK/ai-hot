# Copy to .env and fill real values. Runtime code reads only this root .env.

# Feishu push and bitable
FEISHU_WEBHOOK=
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_CHAT_ID=
FEISHU_BITABLE_URL=
BITABLE_APP_TOKEN=
BITABLE_TABLE_ID=

# TikTok scrape: Apify primary, RapidAPI fallback
APIFY_TOKEN=
APIFY_TOKEN_POOL=
APIFY_TIKTOK_ACTOR_ID=GdWCkxBtKWOsKjdch
RAPIDAPI_KEY=
RAPIDAPI_KEY_2=
RAPIDAPI_TIKTOK_HOST=tiktok-api23.p.rapidapi.com
RAPIDAPI_TIKTOK_SEARCH_PATH=/api/search/video
RAPIDAPI_TIKTOK_HOT_FEED_KEY=
RAPIDAPI_TIKTOK_HOT_FEED_PATH=
TIKTOK_MAX_SEARCH_QUERIES=10
SCRAPER_FORCE_RAPIDAPI=false

# SocialCrawl TikTok trending fetch. Daily TikTok scraper uses this only when hot_feed is enabled.
SOCIALCRAWL_API_KEY=
SOCIALCRAWL_TIKTOK_TRENDING_URL=https://socialcrawl.dev/v1/tiktok/trending
SOCIALCRAWL_TIKTOK_HOT_FEED_ENABLED=false
SOCIALCRAWL_TIKTOK_REGION=US
SOCIALCRAWL_TIKTOK_TRIM=true
SOCIALCRAWL_TIKTOK_MAX_ITEMS=100
TIKTOK_HOT_FEED_OUTPUT_DIR=skill_runs/tiktok_hot_feed

# Manual US English content push (isolated; not used by scheduled daily pipeline)
US_T1_PUSH_ENABLED=false
US_T1_DEFAULT_SOURCE=cache
US_T1_COUNTRY=US
US_T1_LANGUAGE=en
US_T1_ENFORCE_HEAT=false
US_T1_MAX_ITEMS=5
US_T1_REVIEW_MODEL=qwen/qwen3.7-max

# X scrape: RapidAPI twitter241 /search-v3
X_RAPIDAPI_KEY=
X_RAPIDAPI_HOST=twitter241.p.rapidapi.com
X_SEARCH_COUNT=20
X_MAX_SEARCH_QUERIES=20
X_PAGES_PER_TERM=5
X_MIN_FILTERED_PER_TERM=5
X_MAX_FILTERED_PER_TERM=20
X_MAX_HOURS_AGO=72
X_MAX_VIDEO_DURATION_SECONDS=30
X_QUALITY_CREATORS_ENABLED=true
X_QUALITY_CREATORS_SHEET_URL=https://scnmrtumk0zm.feishu.cn/wiki/HLs9wvAACiq5HzkM7cDcmYkAnwf?sheet=yYzT06
X_QUALITY_CREATORS_MAX_ACCOUNTS=20
X_QUALITY_CREATORS_POSTS_PER_ACCOUNT=20
X_QUALITY_CREATORS_PAGES_PER_ACCOUNT=1
X_QUALITY_CREATORS_REDUCE_QUERIES_PER_HIT=2
X_QUALITY_CREATORS_MIN_SEARCH_QUERIES=8
X_REPLIES_ENDPOINT=/tweet/replies
X_REPLIES_ID_PARAM=pid
X_REPLIES_COUNT_PARAM=count
X_SCORING_PLAY_WEIGHT=0.01
X_SCORING_LIKE_WEIGHT=1
X_SCORING_COMMENT_WEIGHT=5
X_SCORING_GRAVITY=1.8
X_SCORING_HIGH_SCORE_K=500

# Instagram scrape: isolated creator-pool path. Uses RapidAPI for creator profile posts.
INS_PROVIDER=rapidapi
INS_CREATOR_POOL_CSV=AIGC-INS.csv
INS_LOOKBACK_HOURS=48
INS_MAX_CREATORS_PER_RUN=24
INS_DATABASE_PATH=skill_runs/instagram/instagram_hotspots.sqlite
INS_HOT_POST_FILTER_ENABLED=true
INS_HOT_BASELINE_DAYS=7
INS_TOP_N=10
INS_MIN_LIKE_COUNT=80
INS_MIN_COMMENT_COUNT=2
INS_MIN_SCORE=20
INS_POSTS_ONLY=true
INS_IMAGE_MATERIALS_ONLY=true
INS_INTRO_ANALYSIS_ENABLED=true
INS_INTRO_ANALYSIS_MODEL=qwen/qwen3.6-plus
INS_INTRO_ANALYSIS_REQUIRE_MODEL=true
INS_INTRO_ANALYSIS_TIMEOUT_SECONDS=45
INS_INTRO_ANALYSIS_MAX_IMAGES=3
INS_RAPIDAPI_KEY=
INS_RAPIDAPI_HOST=instagram120.p.rapidapi.com
INS_RAPIDAPI_BASE_URL=https://instagram120.p.rapidapi.com
INS_RAPIDAPI_POSTS_PATH=/api/instagram/posts
INS_RAPIDAPI_TIMEOUT_SECONDS=45
INS_SAFETY_REVIEW_MODEL=qwen/qwen3.5-plus-20260420
INS_SAFETY_REVIEW_DISABLE=false
INS_DISCOVERY_ENABLED=true
INS_DISCOVERY_WEEKLY=true
INS_DISCOVERY_WEEKDAY=4
INS_DISCOVERY_START_HOUR=10
INS_DISCOVERY_START_MINUTE=0
INS_DISCOVERY_DRY_RUN=false
INS_DISCOVERY_MODEL=qwen/qwen3.5-plus-20260420
INS_DISCOVERY_VALIDATION_LIMIT=50
INS_DISCOVERY_MAX_NEW_CREATORS=50
INS_DISCOVERY_SEARCH_LIMIT_PER_QUERY=10
INS_DISCOVERY_SEARCH_ENGINE_URL=https://duckduckgo.com/html/

# Instagram keyword discovery from high-quality Feishu feedback seeds.
# The daily wrapper runs at 00:01, writes local reports only, and is merged by the 07:00 pipeline.
INS_KEYWORD_DISCOVERY_DAILY_ENABLED=true
INS_KEYWORD_DISCOVERY_DAILY_CRON=1 0 * * *
INS_KEYWORD_DISCOVERY_MERGE_ENABLED=true
INS_KEYWORD_DISCOVERY_REQUIRE_TODAY=true
INS_KEYWORD_DISCOVERY_FAILS_PIPELINE=false
INS_MANUAL_ACCOUNT_COOKIES=www.instagram.com_cookies.txt
INS_MANUAL_SEARCH_HEADLESS=true
INS_MANUAL_MAX_LINKS_PER_QUERY=40
INS_MANUAL_MAX_SCROLLS=12
INS_MANUAL_SEARCH_DELAY_SECONDS=1
INS_MANUAL_ALLOW_RAPIDAPI=false
INS_MANUAL_REVIEW_MODEL=qwen/qwen3.7-max
INS_MANUAL_KEYWORD_POOL_PATH=skill_runs/instagram_keyword_discovery/keyword_pool.json
INS_MANUAL_MAX_POOL_TERMS=0
INS_MANUAL_SHUFFLE_POOL=false
INS_RAPIDAPI_SEARCH_HOST=
INS_RAPIDAPI_SEARCH_PATH=/search
INS_RAPIDAPI_SEARCH_METHOD=GET
INS_RAPIDAPI_SEARCH_QUERY_PARAM=q

# TikTok keyword discovery from high-quality Feishu feedback seeds.
# The daily wrapper runs at 00:01 as an isolated cookie/browser process and writes local reports only.
TIKTOK_KEYWORD_DISCOVERY_DAILY_ENABLED=false
TIKTOK_KEYWORD_DISCOVERY_MERGE_ENABLED=false
TIKTOK_KEYWORD_DISCOVERY_REQUIRE_TODAY=true
TIKTOK_KEYWORD_DISCOVERY_FAILS_PIPELINE=false
TIKTOK_KEYWORD_DISCOVERY_COOKIE_FILE=www.tiktok.com_cookies.txt
TIKTOK_KEYWORD_DISCOVERY_PRODUCT_DOC_PATH=references/product_material_requirements.md
TIKTOK_KEYWORD_DISCOVERY_ROOT=skill_runs/tiktok_keyword_discovery
TIKTOK_KEYWORD_DISCOVERY_MAX_TERMS=100
TIKTOK_KEYWORD_DISCOVERY_TERMS_PER_SEED=5
TIKTOK_KEYWORD_DISCOVERY_ALLOCATION=50
TIKTOK_KEYWORD_DISCOVERY_LOOKBACK_DAYS=7
TIKTOK_KEYWORD_DISCOVERY_LAYERED_ENABLED=false
TIKTOK_KEYWORD_DISCOVERY_LAYER_CONFIG=references/tiktok_discovery_keyword_layers.json
TIKTOK_KEYWORD_DISCOVERY_EXTERNAL_SOURCES_ENABLED=true
TIKTOK_KEYWORD_DISCOVERY_BROWSER_CHANNEL=msedge
TIKTOK_KEYWORD_DISCOVERY_BROWSER_EXECUTABLE=
TIKTOK_KEYWORD_DISCOVERY_HEADLESS=false
TIKTOK_KEYWORD_DISCOVERY_DETAIL_HEADLESS=true
TIKTOK_KEYWORD_DISCOVERY_MAX_SCROLLS=40
TIKTOK_KEYWORD_DISCOVERY_WAIT_MS=1400
TIKTOK_KEYWORD_DISCOVERY_SCROLL_WAIT_MIN_MS=2000
TIKTOK_KEYWORD_DISCOVERY_SCROLL_WAIT_MAX_MS=4000
TIKTOK_KEYWORD_DISCOVERY_MAX_NO_GROWTH_ROUNDS=6
TIKTOK_KEYWORD_DISCOVERY_VERIFICATION_POLL_SECONDS=5
TIKTOK_KEYWORD_DISCOVERY_VERIFICATION_WAIT_SECONDS=200

# Optional LLM/API keys used by feedback optimization
OPENAI_API_KEY=
OPENAI_FEEDBACK_MODEL=gpt-5.4
OPENROUTER_API_KEY=
OPENROUTER_MODEL=
AUTO_PROMPT_EXTRACTION_ENABLED=true
AUTO_PROMPT_MODEL=qwen/qwen3.7-max
AUTO_PROMPT_REQUIRE_MODEL=true
AUTO_PROMPT_MAX_COMMENTS=10
AUTO_PROMPT_MAX_TEXT_CHARS=6000
AUTO_PROMPT_SOURCE_REHYDRATE_ENABLED=true
AUTO_PROMPT_SOURCE_REHYDRATE_MODE=no_api
AUTO_PROMPT_SOURCE_REHYDRATE_CACHE_DIR=skill_runs/source_rehydrate
AUTO_PROMPT_SOURCE_REHYDRATE_TIMEOUT_SECONDS=30
AUTO_PROMPT_SOURCE_REHYDRATE_MAX_COMMENTS=20
AUTO_PROMPT_USE_LOCAL_COOKIES=true
AUTO_PROMPT_COOKIE_FILE=skill_runs/cookies/source_rehydrate_cookies.json
AUTO_PROMPT_COOKIE_DOMAINS=x.com,tiktok.com,instagram.com
AUTO_PROMPT_COOKIE_TIMEOUT_SECONDS=30
AUTO_PROMPT_BROWSER_REHYDRATE_ENABLED=true
AUTO_PROMPT_BROWSER_REHYDRATE_PLATFORMS=x
AUTO_PROMPT_BROWSER_HEADLESS=true
AUTO_PROMPT_BROWSER_TIMEOUT_SECONDS=45
AUTO_PROMPT_BROWSER_WAIT_AFTER_LOAD_MS=1500
AUTO_PROMPT_BROWSER_CACHE_VERSION=browser_v1
AUTO_PROMPT_X_DETAIL_ENABLED=true
AUTO_PROMPT_TIKTOK_DETAIL_ENABLED=true
AUTO_PROMPT_INS_DETAIL_ENABLED=true
VISUAL_DEDUPE_MODEL=qwen/qwen3.6-flash
VISUAL_DEDUPE_HISTORY_DAYS=15
VISUAL_DEDUPE_DISABLE=false
X_SAFETY_REVIEW_MODEL=qwen/qwen3.6-flash
X_SAFETY_REVIEW_DISABLE=false
INTRO_ANALYSIS_MODEL=
INTRO_ANALYSIS_TIMEOUT_SECONDS=45
ANTHROPIC_API_KEY=
MEMORIES_API_KEY=
FEEDBACK_DISABLE_AI=false

# Heat score defaults. Feedback rules can override and sync these values.
SCORING_PLAY_WEIGHT=0.01
SCORING_LIKE_WEIGHT=1
SCORING_COMMENT_WEIGHT=5
SCORING_GRAVITY=1.8
SCORING_HIGH_SCORE_K=500

# Runtime
PIPELINE_PLATFORMS=tiktok,x,ins
PIPELINE_PARALLEL_PLATFORMS=true
PIPELINE_MAX_WORKERS=3
PIPELINE_PLATFORM_TIMEOUT_SECONDS=5400
PIPELINE_TIKTOK_TIMEOUT_SECONDS=7200
PIPELINE_X_TIMEOUT_SECONDS=3600
PIPELINE_INS_TIMEOUT_SECONDS=3600
PIPELINE_CONTINUE_ON_PLATFORM_FAILURE=true
PIPELINE_MONITOR_DIR=skill_runs/pipeline_monitor
SCRAPE_CHECKPOINT_DIR=skill_runs/scrape_checkpoints
SCRAPE_PARTIAL_CONTINUE=true
TARGET_DATE=
FEISHU_DRY_RUN=false
TOP_COMMENTS_LIMIT=20
